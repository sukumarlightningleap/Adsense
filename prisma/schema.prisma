// Adsense — Postgres schema (Prisma).
//
// Ported from adwords-benchmarks/src/launcher/db/models.py (SQLAlchemy).
// Key conventions kept identical so the mental model carries over:
//
//  - Every owned row carries `userId` → per-user data isolation at query time.
//  - Demo data carries `demoMode = true`. Demo is **org-wide**: every demo
//    user sees the same shared set. Live data is per-user.
//  - Money stays in MICROS at the DB boundary (matches Google Ads native
//    shape). UI converts to dollars at render time.
//  - The old "Account" model is RENAMED here to `AdsAccount` to avoid a
//    name clash with NextAuth's future OAuth `Account` model.

// Prisma 7: the `datasource` block now only declares the PROVIDER. The
// connection URL lives in `prisma.config.ts` (CLI) and is passed to the
// Neon adapter at runtime in `src/lib/db.ts` (client).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ---------------------------------------------------------------------------
// Enums (Postgres-backed for type safety + cheap storage)
// ---------------------------------------------------------------------------
enum UserRole {
  admin
  member
  demo
}

enum CampaignStatus {
  ENABLED
  PAUSED
  REMOVED
}

enum ChannelType {
  SEARCH
  PMAX
  DISPLAY
  VIDEO
  DISCOVERY
}

enum AssetKind {
  image
  logo
  pdf
  video
}

enum AssetRole {
  marketing_image
  square_marketing_image
  portrait_marketing_image
  logo
  square_logo
  landscape_logo
}

/// Where a row originated. `created` = built in our app; `imported` =
/// pulled from a Google Ads account during the adoption flow. Used so the
/// UI can show "Imported from Google" badges + so we can apply different
/// edit rules (e.g. write-back warnings on imported rows).
enum Source {
  created
  imported
}

enum KeywordMatchType {
  EXACT
  PHRASE
  BROAD
}

/// Mirrors Google Ads `ConversionAction.category`. We accept the most
/// common categories and fall back to `OTHER` for anything exotic.
enum ConversionCategory {
  PAGE_VIEW
  PURCHASE
  SIGNUP
  LEAD
  DOWNLOAD
  STORE_VISIT
  STORE_SALE
  PHONE_CALL_LEAD
  IMPORTED_LEAD
  SUBMIT_LEAD_FORM
  BOOK_APPOINTMENT
  REQUEST_QUOTE
  ADD_TO_CART
  BEGIN_CHECKOUT
  SUBSCRIBE_PAID
  CONTACT
  GET_DIRECTIONS
  OTHER
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  hashedPassword String    @map("hashed_password")
  // admin: everything + can create users.
  // member: live data only; demo toggle is hidden.
  // demo:   demo data only; demo toggle is forced on.
  role           UserRole  @default(member)
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  accounts       AdsAccount[]
  uploadedAssets Asset[]        @relation("AssetUploader")
  auditEntries   AuditLog[]
  notifications  Notification[]

  @@index([role])
  @@map("users")
}

// ---------------------------------------------------------------------------
// AdsAccount — a Google Ads customer account under management.
// (Renamed from `Account` to avoid clash with NextAuth's OAuth Account model.)
// ---------------------------------------------------------------------------
model AdsAccount {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String   @default("google_ads")
  customerId        String   @map("customer_id")
  descriptiveName   String?  @map("descriptive_name")
  loginCustomerId   String?  @map("login_customer_id")
  currencyCode      String?  @map("currency_code")
  timeZone          String?  @map("time_zone")
  demoMode          Boolean  @default(false) @map("demo_mode")
  createdAt         DateTime @default(now()) @map("created_at")

  // ---- OAuth adoption (Phase 8a) -----------------------------------------
  // Encrypted refresh token for this account's owner. NULL for legacy
  // accounts that fall back to the env-based `GOOGLE_ADS_REFRESH_TOKEN`.
  // Format: AES-256-GCM ciphertext encoded as `iv:tag:cipherHex`.
  oauthRefreshToken  String?   @map("oauth_refresh_token")
  oauthScope         String?   @map("oauth_scope")
  /// 'pending' | 'connected' | 'expired' | 'error'
  connectionStatus   String?   @map("connection_status")
  connectedAt        DateTime? @map("connected_at")
  /// Last time the adoption importer ran for this account.
  lastImportedAt     DateTime? @map("last_imported_at")
  /// MCC customer ID the OAuth user authorized under (may equal customerId
  /// when the user owns the account directly).
  mccCustomerId      String?   @map("mcc_customer_id")
  /// Whether this customer is itself a manager account (MCC). Set on
  /// import from `customer.manager`. Sync skips manager rows because
  /// Google rejects metric queries against them
  /// ("Metrics cannot be requested for a manager account").
  isManager          Boolean   @default(false) @map("is_manager")
  /// Phase 10 — how the daily cron acts on bleed signals:
  ///   'off'           → never touch anything (read-only sync)
  ///   'review_first'  → emit a notification suggesting the action; user
  ///                     reviews + applies manually (DEFAULT — safest)
  ///   'auto'          → pause bleeding ad groups immediately, then
  ///                     emit a notification announcing what was done
  optimizationMode   String    @default("review_first") @map("optimization_mode")

  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns           Campaign[]
  assets              Asset[]                    @relation("AssetAccount")
  benchmarkSnapshots  BenchmarkSnapshot[]
  ga4Link             Ga4LinkStatus?
  ga4OauthConnection  Ga4OAuthConnection?
  conversionActions   ConversionAction[]
  pendingConversions  PendingOfflineConversion[]
  crmWebhookConfigs   CrmWebhookConfig[]
  crmOauthConnections CrmOAuthConnection[]

  @@unique([userId, provider, customerId], name: "uq_account_user_provider_customer")
  @@index([userId])
  @@index([demoMode])
  @@map("ads_accounts")
}

// ---------------------------------------------------------------------------
// Campaign
// ---------------------------------------------------------------------------
model Campaign {
  id                  String         @id @default(cuid())
  accountId           String         @map("account_id")
  providerCampaignId  String?        @map("provider_campaign_id") // numeric Google Ads campaign ID
  name                String
  channelType         ChannelType    @map("channel_type")
  status              CampaignStatus @default(PAUSED)
  dailyBudgetMicros   BigInt?        @map("daily_budget_micros")
  biddingStrategy     String?        @map("bidding_strategy") // MAXIMIZE_CLICKS / TARGET_CPA / MAXIMIZE_CONVERSIONS
  yamlText            String?        @map("yaml_text")        // human-readable YAML (display)
  payloadJson         Json?          @map("payload_json")     // structured payload (launcher reads this)
  // Set on a successful launch — tracks which credential profile pushed
  // this campaign so the operator knows whether it's on test or prod.
  launchedProfile     String?        @map("launched_profile") // 'test' | 'prod' | null
  launchedAt          DateTime?      @map("launched_at")
  /// `created` = built in our app, `imported` = mirrored from Google.
  source              Source         @default(created)
  /// Phase B3 — the ConversionAction this campaign optimizes for. The
  /// bidding strategy is gated on this row's health (working / stale /
  /// broken). NULL is allowed (legacy + freshly-imported campaigns).
  primaryConversionActionId String?  @map("primary_conversion_action_id")
  demoMode            Boolean        @default(false) @map("demo_mode")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  account                  AdsAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dailyKpis                DailyKpi[]
  campaignAssets           CampaignAsset[]
  adGroups                 AdGroup[]
  assetGroups              AssetGroup[]
  primaryConversionAction  ConversionAction? @relation("CampaignPrimaryGoal", fields: [primaryConversionActionId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([providerCampaignId])
  @@index([demoMode])
  @@index([primaryConversionActionId])
  @@map("campaigns")
}

// ---------------------------------------------------------------------------
// AdGroup — a SEARCH-channel ad group within a campaign.
//
// One Campaign can have N ad groups (Phase 8a foundation). PMAX uses
// AssetGroup instead; SEARCH uses AdGroup.
//
// For v1 we embed the single Responsive Search Ad (RSA) fields directly
// on the AdGroup row (headlines / descriptions / finalUrls / paths). When
// we need multi-RSA support we'll promote those into a child `Ad` model.
// ---------------------------------------------------------------------------
model AdGroup {
  id                  String         @id @default(cuid())
  campaignId          String         @map("campaign_id")
  providerAdGroupId   String?        @map("provider_ad_group_id")
  /// The RSA's provider resource ID (separate from the ad group ID).
  providerAdId        String?        @map("provider_ad_id")
  name                String
  /// Theme cluster label — "Branded" / "Informational" / "Competitor" / etc.
  /// Used so bleed-detection can attribute spend to a meaningful bucket.
  themeLabel          String?        @map("theme_label")
  status              CampaignStatus @default(PAUSED)
  cpcBidMicros        BigInt?        @map("cpc_bid_micros")

  /// RSA content embedded for v1 (string[] of headlines, descriptions, URLs)
  headlines           Json
  descriptions        Json
  finalUrls           Json           @map("final_urls")
  path1               String?
  path2               String?

  source              Source         @default(created)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords Keyword[]

  @@index([campaignId])
  @@index([providerAdGroupId])
  @@map("ad_groups")
}

// ---------------------------------------------------------------------------
// Keyword — a positive or negative keyword on an AdGroup.
// ---------------------------------------------------------------------------
model Keyword {
  id                  String           @id @default(cuid())
  adGroupId           String           @map("ad_group_id")
  providerCriterionId String?          @map("provider_criterion_id")
  text                String
  matchType           KeywordMatchType @map("match_type")
  isNegative          Boolean          @default(false) @map("is_negative")
  status              CampaignStatus   @default(ENABLED)
  source              Source           @default(created)
  createdAt           DateTime         @default(now()) @map("created_at")

  adGroup AdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@index([adGroupId])
  @@index([providerCriterionId])
  @@map("keywords")
}

// ---------------------------------------------------------------------------
// AssetGroup — a PMAX asset group within a campaign.
//
// PMAX organizes creatives into asset groups (the rough analog of SEARCH
// ad groups). Each asset group has its own headlines / descriptions /
// images / business name. Phase 10's bleed-detection treats asset groups
// the same way it treats ad groups: bucketed spend → independent decisions.
// ---------------------------------------------------------------------------
model AssetGroup {
  id                     String         @id @default(cuid())
  campaignId             String         @map("campaign_id")
  providerAssetGroupId   String?        @map("provider_asset_group_id")
  name                   String
  themeLabel             String?        @map("theme_label")
  status                 CampaignStatus @default(PAUSED)
  finalUrl               String?        @map("final_url")

  /// PMAX text assets (embedded for v1 simplicity; promote to child models
  /// when we add multi-headline editing per asset).
  headlines              Json
  longHeadlines          Json           @map("long_headlines")
  descriptions           Json
  businessName           String?        @map("business_name")

  source                 Source         @default(created)
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([providerAssetGroupId])
  @@map("asset_groups")
}

// ---------------------------------------------------------------------------
// ConversionAction — mirrors Google Ads ConversionAction.
//
// Critical for Phase 8b (tracking-health audit) — we surface `✓ working`
// / `⚠ stale` / `✗ broken` per row based on `lastConversionAt` +
// `recentConversions`. This is what catches Blue Balloon's broken-since-
// Aug-2025 tracking on day 1 of adoption.
// ---------------------------------------------------------------------------
model ConversionAction {
  id                       String              @id @default(cuid())
  accountId                String              @map("account_id")
  providerConversionId     String?             @map("provider_conversion_id")
  name                     String
  category                 ConversionCategory  @default(OTHER)
  status                   CampaignStatus      @default(ENABLED)
  /// Whether this counts toward the "Conversions" column (vs "All conversions").
  isPrimary                Boolean             @default(true) @map("is_primary")
  /// `ONE_PER_CLICK` | `MANY_PER_CLICK`
  countingType             String?             @map("counting_type")
  /// Days the conversion stays attributable after the click.
  clickThroughLookbackDays Int?                @map("click_through_lookback_days")
  /// Static value per conversion in micros. NULL if dynamic / count-only.
  valueMicros              BigInt?             @map("value_micros")
  /// Last time a conversion actually fired (filled by the daily sync).
  lastConversionAt         DateTime?           @map("last_conversion_at")
  /// Conversion count over a recent rolling window (filled by sync).
  recentConversions        Int?                @map("recent_conversions")
  /// Phase B2 — user attests they've pasted the snippet on their site
  /// (before Google has actually seen the first fire). Lets Create-form
  /// unlock conversion-based bidding in 'learning' mode for net-new
  /// actions that have no `lastConversionAt` yet.
  tagInstalled             Boolean             @default(false) @map("tag_installed")
  source                   Source              @default(imported)
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  account             AdsAccount                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaignsAsPrimary  Campaign[]                  @relation("CampaignPrimaryGoal")
  pendingConversions  PendingOfflineConversion[]
  crmConfigs          CrmWebhookConfig[]          @relation("CrmFeedAction")

  @@index([accountId])
  @@index([providerConversionId])
  @@map("conversion_actions")
}

// ---------------------------------------------------------------------------
// PendingOfflineConversion — queue of offline conversions awaiting upload
// to Google via `ConversionUploadService.uploadClickConversions`.
//
// Sources (Phase B6/B8):
//   - 'hubspot' / 'pipedrive' / 'zoho' — pushed in by the webhook receiver
//     when a CRM deal stage matches the configured trigger
//   - 'csv' — bulk CSV upload from the customer
//   - 'manual' — operator entry (debug / one-off)
//
// The cron `/api/cron/upload-offline-conversions` batches `pending` rows
// per (account, conversion action) and uploads them. Status flips to
// `uploaded` (with `uploadedAt`) or `failed` (with `lastError` + retry).
// Dedup key = (accountId, source, externalId) — prevents the same CRM
// deal-stage-change webhook from firing the same conversion twice.
// ---------------------------------------------------------------------------
model PendingOfflineConversion {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  conversionActionId String   @map("conversion_action_id")

  /// Google's ad-click identifier. Required unless we someday support
  /// Enhanced Conversions for Leads (email/phone match) — for now,
  /// rows without a gclid are rejected at intake.
  gclid              String?
  /// iOS Safari / web-to-app alternatives. Only one of gclid/gbraid/wbraid
  /// needs to be set per row.
  gbraid             String?
  wbraid             String?

  conversionDateTime DateTime @map("conversion_date_time")
  valueMicros        BigInt?  @map("value_micros")
  currencyCode       String?  @map("currency_code")
  /// Order ID for purchase-style conversions (helps Google dedupe at their end).
  orderId            String?  @map("order_id")

  /// 'hubspot' | 'pipedrive' | 'zoho' | 'csv' | 'manual' | 'ga4_offline'
  source             String
  /// Foreign-system unique ID (e.g. HubSpot deal ID) — used for dedupe.
  externalId         String?  @map("external_id")

  status             String   @default("pending") // pending | uploaded | failed
  attempts           Int      @default(0)
  lastError          String?  @map("last_error")
  uploadedAt         DateTime? @map("uploaded_at")
  createdAt          DateTime @default(now()) @map("created_at")

  account          AdsAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversionAction ConversionAction @relation(fields: [conversionActionId], references: [id], onDelete: Cascade)

  @@unique([accountId, source, externalId], name: "uq_offline_dedupe")
  @@index([accountId, status])
  @@index([conversionActionId])
  @@index([status])
  @@map("pending_offline_conversions")
}

// ---------------------------------------------------------------------------
// CrmWebhookConfig — per-account secret used to authenticate incoming
// webhook POSTs from CRMs. We give each account a unique secret that
// the customer pastes into HubSpot / Pipedrive / Zoho webhook config.
//
// One row per account per source. The `secret` is a 32-byte random hex
// string. We also store which ConversionAction this CRM source feeds
// into so the webhook body doesn't need to reference our internal IDs.
// ---------------------------------------------------------------------------
model CrmWebhookConfig {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  /// 'hubspot' | 'pipedrive' | 'zoho'
  source             String
  /// 32-byte hex string. Required as `X-Adsense-Webhook-Secret` header.
  secret             String
  /// Default ConversionAction the webhook fires (customer picks at
  /// connection time). Nullable so the row can be created before the
  /// customer chooses, but cron rejects rows that hit a NULL config.
  conversionActionId String?  @map("conversion_action_id")
  /// JSON-encoded mapping rules (e.g. {dealStage: "Proposal Sent"}).
  rules              Json?
  /// Last time we successfully received a webhook fire on this config.
  lastFireAt         DateTime? @map("last_fire_at")
  fireCount          Int      @default(0) @map("fire_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  account          AdsAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversionAction ConversionAction? @relation("CrmFeedAction", fields: [conversionActionId], references: [id], onDelete: SetNull)

  @@unique([accountId, source], name: "uq_crm_per_source")
  @@index([accountId])
  @@map("crm_webhook_configs")
}

// ---------------------------------------------------------------------------
// CrmOAuthConnection — Phase B6.1 (OAuth-based CRM integration).
//
// Adds the OAuth alternative to the manual-webhook flow in
// CrmWebhookConfig. OAuth lets us READ pipeline state from the CRM
// (list pipelines, list stages, list recently-updated deals) rather
// than relying on the customer to configure outbound webhooks.
//
// One row per (account × provider). The token vault encrypts both
// access + refresh tokens at rest (AES-256-GCM via token-vault.ts).
// ---------------------------------------------------------------------------
model CrmOAuthConnection {
  id                    String   @id @default(cuid())
  accountId             String   @map("account_id")
  /// 'hubspot' | 'pipedrive' | 'zoho'
  provider              String

  /// AES-256-GCM encrypted access token.
  encryptedAccessToken  String   @map("encrypted_access_token")
  /// Refresh token (encrypted). Some providers don't return one; we
  /// then have to re-OAuth when the access token expires.
  encryptedRefreshToken String?  @map("encrypted_refresh_token")
  tokenExpiresAt        DateTime? @map("token_expires_at")
  scope                 String?

  /// Zoho only: 'us' | 'eu' | 'in' | 'au' | 'jp' (drives API base URL).
  region                String?
  /// Provider-side identifier (HubSpot portal_id / Pipedrive company_id /
  /// Zoho org_id) so we know WHICH account this connection is on the
  /// CRM side without an extra round-trip.
  providerAccountId     String?  @map("provider_account_id")

  /// Cron-driven polling state. `lastDealUpdatedAt` is the watermark —
  /// next poll asks "deals updated since this timestamp".
  lastPolledAt          DateTime? @map("last_polled_at")
  lastDealUpdatedAt     DateTime? @map("last_deal_updated_at")
  lastPollError         String?   @map("last_poll_error")

  /// Which pipeline stages we treat as conversion triggers, mapped
  /// stage→conversionActionId. Shape: { "<stage_id>": "<our action id>" }.
  /// When a deal's stage matches a key, we enqueue against that action.
  stageRules            Json?     @map("stage_rules")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  account AdsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, provider], name: "uq_crm_oauth_per_provider")
  @@index([accountId])
  @@map("crm_oauth_connections")
}

// ---------------------------------------------------------------------------
// Ga4OAuthConnection — Phase B5.1.
//
// Stores OAuth tokens for the Google Analytics Admin API
// (`https://www.googleapis.com/auth/analytics.readonly`). Used by the
// GA4-import flow to list properties + key events without making the
// customer paste IDs by hand.
//
// Reuses the same AES-256-GCM token vault as Google Ads + CRM OAuth.
// One connection per AdsAccount.
// ---------------------------------------------------------------------------
model Ga4OAuthConnection {
  id                    String   @id @default(cuid())
  accountId             String   @unique @map("account_id")

  encryptedAccessToken  String   @map("encrypted_access_token")
  encryptedRefreshToken String?  @map("encrypted_refresh_token")
  tokenExpiresAt        DateTime? @map("token_expires_at")
  scope                 String?
  /// Email of the Google user who completed the OAuth flow (shown
  /// in the UI as "Connected as foo@bar.com").
  oauthEmail            String?  @map("oauth_email")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  account AdsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("ga4_oauth_connections")
}

// ---------------------------------------------------------------------------
// DailyKpi — one row per campaign per date. Idempotent re-syncs via unique key.
// ---------------------------------------------------------------------------
model DailyKpi {
  id                    String   @id @default(cuid())
  campaignId            String   @map("campaign_id")
  date                  DateTime @db.Date
  impressions           BigInt   @default(0)
  clicks                BigInt   @default(0)
  costMicros            BigInt   @default(0) @map("cost_micros")
  conversions           Float    @default(0)
  conversionValueMicros BigInt   @default(0) @map("conversion_value_micros")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date], name: "uq_daily_kpi_campaign_date")
  @@index([campaignId])
  @@map("daily_kpis")
}

// ---------------------------------------------------------------------------
// DailyAdGroupKpi — one row per ad group per date.
//
// Required for bleed detection (Phase 10): we attribute spend / conversions
// to the smallest meaningful bucket, so we can pause individual ad groups
// rather than killing whole campaigns when one theme is bleeding.
// ---------------------------------------------------------------------------
model DailyAdGroupKpi {
  id                    String   @id @default(cuid())
  adGroupId             String   @map("ad_group_id")
  date                  DateTime @db.Date
  impressions           BigInt   @default(0)
  clicks                BigInt   @default(0)
  costMicros            BigInt   @default(0) @map("cost_micros")
  conversions           Float    @default(0)
  conversionValueMicros BigInt   @default(0) @map("conversion_value_micros")

  @@unique([adGroupId, date], name: "uq_daily_ad_group_kpi_date")
  @@index([adGroupId])
  @@map("daily_ad_group_kpis")
}

// ---------------------------------------------------------------------------
// Asset — image / logo / pdf / video bytes stored in Postgres.
// userId = uploader (org-wide pool — any campaign on any account can link).
// accountId = optional "first uploaded for" tag.
// ---------------------------------------------------------------------------
model Asset {
  id                   String    @id @default(cuid())
  userId               String?   @map("user_id")
  accountId            String?   @map("account_id")
  /// FK to parent Asset for resized variants. NULL for originals.
  parentAssetId        String?   @map("parent_asset_id")
  /// Image dimensions. Set by the resize pipeline; NULL for non-image
  /// assets (pdf / video) or pre-resize originals.
  width                Int?
  height               Int?
  /// AssetRole that this variant fills (square_logo / landscape, etc.).
  /// Originals have NULL; variants get the role they were sized for.
  variantRole          AssetRole? @map("variant_role")
  name                 String?
  kind                 AssetKind
  mime                 String
  sha256               String
  bytes                Bytes
  providerResourceName String?   @map("provider_resource_name")
  /// `created` for uploaded/AI-generated, `imported` for assets pulled
  /// from Google during account adoption.
  source               Source    @default(created)
  demoMode             Boolean   @default(false) @map("demo_mode")
  createdAt            DateTime  @default(now()) @map("created_at")

  uploader      User?           @relation("AssetUploader", fields: [userId], references: [id], onDelete: SetNull)
  account       AdsAccount?     @relation("AssetAccount", fields: [accountId], references: [id], onDelete: SetNull)
  parent        Asset?          @relation("AssetVariants", fields: [parentAssetId], references: [id], onDelete: Cascade)
  variants      Asset[]         @relation("AssetVariants")
  campaignLinks CampaignAsset[]

  @@index([userId])
  @@index([accountId])
  @@index([sha256])
  @@index([demoMode])
  @@index([parentAssetId])
  @@map("assets")
}

model CampaignAsset {
  campaignId String    @map("campaign_id")
  assetId    String    @map("asset_id")
  role       AssetRole

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([campaignId, assetId])
  @@map("campaign_assets")
}

// ---------------------------------------------------------------------------
// BenchmarkSnapshot — output of adwords_benchmark, persisted per account.
// ---------------------------------------------------------------------------
model BenchmarkSnapshot {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  generatedAt   DateTime @default(now()) @map("generated_at")
  schemaVersion String   @default("1") @map("schema_version")
  reportJson    Json     @map("report_json")

  account AdsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("benchmark_snapshots")
}

// ---------------------------------------------------------------------------
// Ga4LinkStatus — one row per account.
// ---------------------------------------------------------------------------
model Ga4LinkStatus {
  accountId     String    @id @map("account_id")
  ga4PropertyId String?   @map("ga4_property_id")
  linked        Boolean   @default(false)
  lastCheckedAt DateTime? @map("last_checked_at")

  account AdsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("ga4_link_status")
}

// ---------------------------------------------------------------------------
// Notification — Phase 11 inbox + email queue.
//
// Anything the autopilot does on the customer's behalf (auto-pause a
// bleeder, fix a broken tracker, etc.) creates a Notification row.
// The deliverer cron picks up `status='pending'` rows and sends them
// via Resend (email) — falling back to "in-app only" if no API key is
// configured. Future: SMS via Twilio, WhatsApp via Twilio Business,
// weekly AI-written PDF report.
// ---------------------------------------------------------------------------
model Notification {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  /// Optional — when the notification is about a specific account.
  accountId     String?   @map("account_id")
  /// 'auto_pause' | 'pause_suggestion' | 'tracking_break' |
  /// 'import_error' | 'launch_success' | 'weekly_report' | etc.
  kind          String
  /// 'info' | 'warning' | 'error'
  severity      String    @default("info")
  title         String
  body          String
  /// Free-form structured payload (e.g. {adGroupId, cpa, threshold}).
  payload       Json?
  /// Delivery state: 'pending' (in queue), 'sent' (delivered), 'failed',
  /// 'skipped' (no channel configured — in-app inbox only).
  status        String    @default("pending")
  /// Set when the user opens the inbox + clicks the row.
  readAt        DateTime? @map("read_at")
  /// When the deliverer last tried — set on success OR failure.
  deliveredAt   DateTime? @map("delivered_at")
  deliveryError String?   @map("delivery_error")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// AuditLog — immutable who-did-what trail.
// ---------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String // "user.login", "user.create", "campaign.launch", etc.
  targetKind String?  @map("target_kind")
  targetId   String?  @map("target_id")
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}
