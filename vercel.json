{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/sync-metrics",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/deliver-notifications",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/upload-offline-conversions",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/poll-crm-connections",
      "schedule": "*/15 * * * *"
    }
  ]
}
